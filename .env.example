# Supabase Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real values to version control

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Medical Parameter Registry
# Optional: URL to remote parameter registry for dynamic updates
# VITE_PARAM_REGISTRY_URL=""

# Feature Flags
# VITE_ENABLE_IMU=true
# VITE_FORENSIC_STRICT_MODE=true
